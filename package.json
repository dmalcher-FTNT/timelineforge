{
  "name": "timelineforge",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/check-vendor.mjs",
    "pretest": "node scripts/check-vendor.mjs",
    "build": "node scripts/build-release.mjs",
    "package": "node scripts/package-archive.mjs",
    "test": "node --test tests/unit/*.test.js tests/smoke/*.test.js",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e",
    "release": "npm run build && npm run test:all",
    "screenshots": "playwright test tests/e2e/readme-screenshots.spec.js",
    "vendor": "node scripts/sync-vendor.mjs"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "d3": "7.9.0",
    "esbuild": "^0.25.0",
    "html2canvas": "1.4.1",
    "jspdf": "2.5.2",
    "mammoth": "1.8.0",
    "mermaid": "11.4.0",
    "pptxgenjs": "3.12.0",
    "fflate": "^0.8.2",
    "sharp": "^0.35.2",
    "svg2pdf.js": "2.2.4"
  }
}
